# Tracked, non-secret CI defaults for secretless PR validation.
# The pull_request workflow copies this file into `.env.local` and `.env.test.local`.
# Add your project's env vars here using placeholder values shaped like the real ones
# (URLs must parse as URLs, secrets must satisfy your schema's minLength, etc).
# Real secrets live in protected GitHub environments and Vercel, never in this file.

DATABASE_URL=postgresql://ci:ci@db.example.com/{{PROJECT_SLUG}}_ci
NEXT_PUBLIC_APP_URL=https://ci.{{PROJECT_SLUG}}.example
